generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  LOST
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum FollowUpStatus {
  PENDING
  CONTACTED
  WAITING
  CLOSED
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
}

enum ActivityType {
  CLIENT_ADDED
  CLIENT_UPDATED
  INVOICE_CREATED
  INVOICE_UPDATED
  PAYMENT_RECEIVED
  REMINDER_SENT
  FOLLOWUP_CREATED
  FOLLOWUP_COMPLETED
  FOLLOWUP_UPDATED
  PROJECT_CREATED
  PROJECT_UPDATED
}

enum EmailType {
  PAYMENT_REMINDER
  FOLLOWUP_REMINDER
}

enum EmailStatus {
  SENT
  FAILED
  PENDING
}

enum ReminderType {
  SEVEN_DAYS
  THREE_DAYS
  DUE_DATE
  OVERDUE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients        Client[]
  dataEntries    DataEntry[]
  emailTemplates EmailTemplate[]
  emailLogs      EmailLog[]
  activities     Activity[]
}

model DataEntry {
  id           String   @id @default(cuid())
  userId       String
  name         String
  businessName String?
  location     String?
  instagram    String?
  website      String?
  remark       String?
  leadClientId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, name])
}

model Client {
  id          String       @id @default(cuid())
  userId      String
  name        String
  companyName String?
  email       String?
  phone       String?
  country     String?
  state       String?
  city        String?
  website     String?
  notes       String?
  remark      String?
  status      ClientStatus @default(LEAD)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects   Project[]
  followUps  FollowUp[]
  invoices   Invoice[]
  payments   Payment[]
  activities Activity[]
  emailLogs  EmailLog[]

  @@index([userId, status])
  @@index([userId, name])
  @@index([email])
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  projectName String
  description String?
  totalAmount Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(12, 2)
  startDate   DateTime?
  deadline    DateTime?
  status      ProjectStatus @default(PLANNING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([deadline])
}

model Invoice {
  id            String        @id @default(cuid())
  clientId      String
  invoiceNumber String
  amount        Decimal       @db.Decimal(12, 2)
  dueDate       DateTime
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([clientId, invoiceNumber])
  @@index([clientId, status])
  @@index([dueDate, status])
}

model Payment {
  id          String   @id @default(cuid())
  clientId    String
  invoiceId   String?
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime
  method      String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([paymentDate])
}

model FollowUp {
  id               String         @id @default(cuid())
  clientId         String
  note             String
  nextFollowUpDate DateTime
  status           FollowUpStatus @default(PENDING)
  reminderSent     Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([nextFollowUpDate, status])
  @@index([clientId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@index([userId])
}

model EmailLog {
  id           String       @id @default(cuid())
  userId       String
  clientId     String
  templateId   String?
  to           String
  subject      String
  body         String
  type         EmailType
  status       EmailStatus  @default(PENDING)
  reminderType ReminderType?
  invoiceId    String?
  followUpId   String?
  sentAt       DateTime     @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
  @@index([invoiceId, reminderType])
  @@index([followUpId])
}

model Activity {
  id          String       @id @default(cuid())
  userId      String
  clientId    String
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([userId, createdAt])
}
